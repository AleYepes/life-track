{
  "manifest_version": 3,
  "name": "ActivityWatch Title Extender",
  "version": "3.0",
  "description": "Enriches browser tab titles with metadata (URL, audio status, channel/sender info) for ActivityWatch window-tracking.",
  "permissions": ["tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["main-world.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
